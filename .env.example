# Copy this file to `.env` and fill in the key for the stack you choose.
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Prompt engineering is provider-agnostic — pick whichever you already have.
#
#   openai  -> OpenAI chat        (needs OPENAI_API_KEY)
#   claude  -> Claude messages    (needs ANTHROPIC_API_KEY)
#
# Default is "openai".
# ---------------------------------------------------------------------------
PROVIDER=openai

# --- For PROVIDER=openai ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- For PROVIDER=claude ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional: override the chat model for the active stack ---
# Defaults: gpt-4o-mini (openai) / claude-haiku-4-5 (claude).
# MODEL=gpt-4o

# --- Optional: a dedicated reasoning model for fundamentals/14 ---
# REASONING_MODEL=o4-mini

# ---------------------------------------------------------------------------
# Run a LOCAL model instead (Ollama, LM Studio, llama.cpp, vLLM).
# Local servers speak the OpenAI API, so keep PROVIDER=openai and point the
# base URL at the local endpoint. Any non-empty key works.
#
#   PROVIDER=openai
#   OPENAI_API_KEY=local
#   OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama (LM Studio :1234, llama.cpp :8080, vLLM :8000)
#   MODEL=llama3.1
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=
